<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.minerva.agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>{{VAULT_PATH}}/scripts/mac_watcher.sh</string>
    </array>

    <key>WatchPaths</key>
    <array>
        <string>{{VAULT_PATH}}/raw_sources/</string>
        <string>{{VAULT_PATH}}/manager_review/</string>
    </array>

    <key>StandardOutPath</key>
    <string>/tmp/minerva_launchd.out</string>

    <key>StandardErrorPath</key>
    <string>/tmp/minerva_launchd.err</string>

    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>